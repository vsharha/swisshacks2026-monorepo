# Copy this file to .env and fill in the values.
# Single source of truth for both callers (@kyc/web live runtime + @kyc/scripts offline).

# EventRegistry (https://eventregistry.org) — news intelligence API
EVENTREGISTRY_API_KEY=

# LLM API key for Stage 2/3 reasoning (optional; the cheap tiers run without it).
# Defaults to Apertus — the Swiss open LLM — over Public AI
# (https://platform.publicai.co/docs).
LLM_API_KEY=

# Optional overrides — point the same code at any OpenAI-compatible provider.
# Leave unset to use the Apertus / Public AI defaults. Example for OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_STAGE2_MODEL=gpt-5.4-mini
#   LLM_STAGE3_MODEL=gpt-5.4
LLM_BASE_URL=
LLM_STAGE2_MODEL=
LLM_STAGE3_MODEL=
