# Copy this file to .env and fill in the values.
# Single source of truth for both callers (@kyc/web live runtime + @kyc/scripts offline).

# EventRegistry (https://eventregistry.org) — news intelligence API
EVENTREGISTRY_API_KEY=

# Anthropic API key — powers Stage 2/3 LLM reasoning (optional; the cheap tiers
# run without it). https://console.anthropic.com
ANTHROPIC_API_KEY=
