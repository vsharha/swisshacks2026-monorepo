# Copy this file to .env and fill in the values.
# Single source of truth for both callers (@kyc/web live runtime + @kyc/scripts offline).

# EventRegistry (https://eventregistry.org) — news intelligence API
EVENTREGISTRY_API_KEY=

# Public AI (https://platform.publicai.co/docs) — serves Apertus, the Swiss open
# LLM, for Stage 2/3 reasoning (optional; the cheap tiers run without it).
PUBLICAI_API_KEY=
