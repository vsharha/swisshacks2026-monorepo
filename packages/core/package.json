{
  "name": "@kyc/core",
  "version": "1.0.0",
  "description": "Framework-agnostic shared library: schemas, connectors, pipeline, drift, audit",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./connectors": "./src/connectors/index.ts",
    "./pipeline": "./src/pipeline/index.ts",
    "./graph": "./src/graph/index.ts",
    "./util": "./src/util/index.ts",
    "./drift": "./src/drift/index.ts",
    "./governance": "./src/governance/index.ts",
    "./llm": "./src/llm/index.ts",
    "./llm/cost": "./src/llm/cost.ts"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fix": "eslint src --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@mozilla/readability": "^0.6.0",
    "ai": "^6.0.208",
    "jsdom": "^29.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.3.0",
    "jiti": "^2.4.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.9"
  }
}
